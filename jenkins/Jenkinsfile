stage('Deploy to Dev') {
            steps {
                withCredentials([
                    file(credentialsId: 'releasegate-kubeconfig', variable: 'KUBECONFIG_PATH'),
                    [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-ecr', accessKeyVariable: 'AWS_ACCESS_KEY_ID', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
                ]) {
                    sh '''
                        export KUBECONFIG="${KUBECONFIG_PATH}"
                        export AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}"
                        export AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}"
                        export AWS_DEFAULT_REGION="us-east-1"
                        
                        # Get the short commit SHA natively in the shell
                        IMAGE_TAG=$(git rev-parse --short HEAD)
                        
                        kubectl create namespace dev --dry-run=client -o yaml | kubectl apply -f -
                        
                        ECR_PASSWORD=$(aws ecr get-login-password --region us-east-1)
                        kubectl create secret docker-registry ecr-registry-secret \
                            --docker-server="${ECR_REPO}" \
                            --docker-username=AWS \
                            --docker-password="${ECR_PASSWORD}" \
                            --namespace dev \
                            --dry-run=client -o yaml | kubectl apply -f -
                        
                        helm upgrade --install releasegate-dev ./helm-chart \
                            -f ./helm-chart/values-dev.yaml \
                            --set image.repository="${ECR_REPO}" \
                            --set image.tag="${IMAGE_TAG}" \
                            --namespace dev \
                            --wait --timeout 10m
                    '''
                }
            }
        }

        stage('Health Check: Dev') {
            steps {
                withCredentials([file(credentialsId: 'releasegate-kubeconfig', variable: 'KUBECONFIG_PATH')]) {
                    sh '''
                        export KUBECONFIG="${KUBECONFIG_PATH}"
                        kubectl rollout status deployment/releasegate-app-dev --namespace dev --timeout=120s
                    '''
                }
            }
        }

        stage('Promote to Staging') {
            steps {
                withCredentials([
                    file(credentialsId: 'releasegate-kubeconfig', variable: 'KUBECONFIG_PATH'),
                    [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-ecr', accessKeyVariable: 'AWS_ACCESS_KEY_ID', secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
                ]) {
                    sh '''
                        export KUBECONFIG="${KUBECONFIG_PATH}"
                        export AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}"
                        export AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}"
                        export AWS_DEFAULT_REGION="us-east-1"
                        
                        # Get the short commit SHA natively in the shell
                        IMAGE_TAG=$(git rev-parse --short HEAD)
                        
                        kubectl create namespace staging --dry-run=client -o yaml | kubectl apply -f -
                        
                        ECR_PASSWORD=$(aws ecr get-login-password --region us-east-1)
                        kubectl create secret docker-registry ecr-registry-secret \
                            --docker-server="${ECR_REPO}" \
                            --docker-username=AWS \
                            --docker-password="${ECR_PASSWORD}" \
                            --namespace staging \
                            --dry-run=client -o yaml | kubectl apply -f -
                        
                        helm upgrade --install releasegate-staging ./helm-chart \
                            -f ./helm-chart/values-staging.yaml \
                            --set image.repository="${ECR_REPO}" \
                            --set image.tag="${IMAGE_TAG}" \
                            --namespace staging \
                            --wait --timeout 10m
                    '''
                }
            }
        }